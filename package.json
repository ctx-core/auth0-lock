{
	"name": "@ctx-core/auth0-lock",
	"version": "15.4.336",
	"description": "ctx-core auth0-lock",
	"keywords": [
		"ctx-core",
		"auth0",
		"auth0-lock"
	],
	"homepage": "https://github.com/ctx-core/auth0-lock#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/auth0-lock/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/auth0-lock.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-auth0-lock@briantakita.me"
	},
	"type": "module",
	"types": "./index.d.ts",
	"exports": {
		".": "./index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:types && bun run test:unit",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit"
	},
	"dependencies": {
		"@ctx-core/auth0": "*",
		"@ctx-core/package": "*",
		"auth0-lock": "^14.2.4",
		"ctx-core": "*"
	},
	"devDependencies": {
		"@types/auth0": "^3.3.11",
		"@types/auth0-js": "^9.21.6",
		"@types/auth0-lock": "^11.27.9",
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}
